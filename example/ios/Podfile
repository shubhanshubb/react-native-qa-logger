# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}#{linkage == 'static' ? ' linkage' : ''}"
  use_frameworks! :linkage => linkage.to_sym
end

target 'QALoggerExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # fmt 11.0.2 (pinned by RCT-Folly) uses `consteval` compile-time format-string
    # checks that Apple Clang 21 / Xcode 26 rejects ("call to consteval function is
    # not a constant expression"). fmt's base.h unconditionally #defines
    # FMT_USE_CONSTEVAL from compiler detection (no #ifndef guard), so a -D define
    # is ignored — we must patch the header to force consteval off. It falls back to
    # constexpr/runtime and builds cleanly. Re-applied on every `pod install`.
    fmt_base = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      contents = File.read(fmt_base)
      patched = contents.gsub('#  define FMT_USE_CONSTEVAL 1', '#  define FMT_USE_CONSTEVAL 0')
      if patched != contents
        # Pod headers are installed read-only (0444); make writable before patching.
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched)
        Pod::UI.puts '[qa-logger] Patched fmt base.h: FMT_USE_CONSTEVAL forced to 0 (Clang 21 fix)'
      end
    end
  end
end
